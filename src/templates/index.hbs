{{#> layouts._html-shell
    title=(localize "page-title")
    pageClass="v_home"
    pageUrl=(join "https://wiki.cocube.fun/" locale.code "/index.html")
    pageDescription=(localize "hero-description")
}}

{{#*inline "main-content"}}


{{!-- <!-- Header -->
<header class="v_home__hero c_hero-yellow">
    <div class="c_hero-home">

        <div class="c_hero-home__logo">
            {{> svg.learn-microblocks-block }}
            <div class="c_hero-home__bubble c_hero-home__bubble--l">
                <img src="/assets/img/pictures/duy-loan-le.svg" alt="Duy-Loan Le">
            </div>
            <div class="c_hero-home__bubble c_hero-home__bubble--e">
                <img src="/assets/img/pictures/evelyn-boyd-granville.svg" alt="Evelyn Boyd Granville">
            </div>
            <div class="c_hero-home__bubble c_hero-home__bubble--a">
                <img src="/assets/img/pictures/adele-goldberg.svg" alt="Adele Goldberg">
            </div>
            <div class="c_hero-home__bubble c_hero-home__bubble--r">
                <img src="/assets/img/pictures/rosza-peter.svg" alt="Rósza Péter">
            </div>
            <div class="c_hero-home__bubble c_hero-home__bubble--n">
                <img src="/assets/img/pictures/nashlie-sephus.svg" alt="Nashlie Sephus">
            </div>
        </div>

        <div class="c_hero-home__descriptions">
            <div class="c_hero-home__desc c_hero-home__desc--l">
{{#markdown}}{{localize "le-txt"
    (join "**" (localize "le-name") "**")
}}{{/markdown}}
            </div>
            <div class="c_hero-home__desc c_hero-home__desc--e">
{{#markdown}}{{localize "evelyn-txt"
    (join "**" (localize "evelyn-name") "**")
}}{{/markdown}}
            </div>
            <div class="c_hero-home__desc c_hero-home__desc--a">
{{#markdown}}{{localize "adele-txt"
    (join "**" (localize "adele-name") "**")
}}{{/markdown}}
            </div>
            <div class="c_hero-home__desc c_hero-home__desc--r">
{{#markdown}}{{localize "rosza-txt"
    (join "**" (localize "rosza-name") "**")
}}{{/markdown}}
            </div>
            <div class="c_hero-home__desc c_hero-home__desc--n">
{{#markdown}}{{localize "nashlie-txt"
    (join "**" (localize "nashlie-name") "**")
}}{{/markdown}}
            </div>
        </div>
        
    </div>
</header><!-- /Header --> --}}


<!-- Subtitle -->
{{!-- <div class="v_home__subtitle">
    <div class="row">
        <div class="col col-px col-12">
            <h2 class="c_title-block c_title-block--purple">{{localize "top-label"}}</h2>
        </div>
    </div>
</div> --}}


<div class="v_home__shell">
    <section class="v_home__landing">
        <div class="v_home__intro">
            {{!-- <p class="v_home__kicker">{{localize "hero-kicker"}}</p> --}}
            <h1 class="v_home__title">
                <span class="v_home__title-line">{{localize "hero-title-line"}}</span>
                <span class="v_home__title-brand">{{localize "hero-title-brand"}}</span>
            </h1>
            {{!-- <p class="v_home__summary">{{localize "hero-description"}}</p> --}}
        </div>

        <div class="v_home__art">
            <div class="v_home__art-figure">
                <span class="v_home__art-pill v_home__art-pill--blocks">{{localize "blocks-badge"}}</span>
                <img
                    class="v_home__art-image"
                    src="/assets/img/logos/main_img.png"
                    alt="CoCube Robot"
                />
                <span class="v_home__art-pill v_home__art-pill--python">{{localize "python-badge"}}</span>
            </div>
        </div>
    </section>

    <section class="v_home__entries" aria-labelledby="home-entry-title">
        <div class="v_home__entry-panel">
            <div class="v_home__entries-head">
                <h2 id="home-entry-title" class="v_home__entries-title">
                    {{localize "path-title"}}
                </h2>
            </div>

            <div class="v_home__entry-grid">
                <a
                    class="v_home__entry-card v_home__entry-card--blocks"
                    href="./activities/cocube_basic_00_start-{{locale.code}}"
                >
                    <span class="v_home__entry-badge">{{localize "blocks-badge"}}</span>
                    <h3 class="v_home__entry-title">{{localize "blocks-title"}}</h3>
                    <p class="v_home__entry-copy">{{localize "blocks-description"}}</p>
                    <div class="v_home__entry-footer">
                        <span class="v_home__entry-meta">{{localize "blocks-meta"}}</span>
                        <span class="v_home__entry-cta">{{localize "blocks-cta"}}</span>
                    </div>
                </a>

                <a
                    class="v_home__entry-card v_home__entry-card--python"
                    href="https://micropython.cocube.fun/"
                >
                    <span class="v_home__entry-badge">{{localize "python-badge"}}</span>
                    <h3 class="v_home__entry-title">{{localize "python-title"}}</h3>
                    <p class="v_home__entry-copy">{{localize "python-description"}}</p>
                    <div class="v_home__entry-footer">
                        <span class="v_home__entry-meta">{{localize "python-meta"}}</span>
                        <span class="v_home__entry-cta">{{localize "python-cta"}}</span>
                    </div>
                </a>
            </div>
        </div>
    </section>
</div>


{{/inline}}
{{/layouts._html-shell }}
